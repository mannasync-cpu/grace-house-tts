{
    "hosting": {
        "public": "out",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**/*.html",
                "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
            },
            {
                "source": "**/*.js",
                "headers": [{ "key": "Cache-Control", "value": "max-age=3600, must-revalidate" }]
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    }
}